
{
  "entities": {
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student user registered on the Al-Bashmohandes platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "studentPhoneNumber": { "type": "string" },
        "parentPhoneNumber": { "type": "string" },
        "academicYear": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "lastLoginDate": { "type": "string", "format": "date-time" },
        "points": { "type": "number" }
      },
      "required": ["id", "name", "email", "studentPhoneNumber", "parentPhoneNumber", "academicYear", "registrationDate"]
    },
    "WhatsAppConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WhatsAppConfig",
      "type": "object",
      "description": "Stores WhatsApp API and sender configuration.",
      "properties": {
        "senderNumber": { "type": "string", "description": "The official WhatsApp number used for sending." },
        "apiKey": { "type": "string", "description": "Optional API key for professional gateway providers." },
        "status": { "type": "string", "enum": ["connected", "disconnected"] },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "targetAcademicYear": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/admin_config/whatsapp",
        "definition": {
          "entityName": "WhatsAppConfig",
          "schema": { "$ref": "#/backend/entities/WhatsAppConfig" },
          "description": "Singleton config for WhatsApp integration."
        }
      },
      {
        "path": "/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": { "$ref": "#/backend/entities/Student" },
          "description": "Student profiles."
        }
      },
      {
        "path": "/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": { "$ref": "#/backend/entities/Course" },
          "description": "Courses collection."
        }
      }
    ]
  }
}
