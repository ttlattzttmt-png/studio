rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه مسؤول (Admin)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@al-bashmohandes.com" ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    // دالة التحقق من ملكية البيانات
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- القواعد ---

    // الإشعارات: قراءة للجميع، كتابة للمسؤول
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // أدوار ومستخدمي الإدارة
    match /admin_roles/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com");
    }
    match /admin_users/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
    }

    // الكورسات ومحتواها
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /{allSubcollections=**} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // أكواد الوصول: 
    // - القراءة والبحث (list) مسموحة لجميع المسجلين للتحقق من الكود (ضروري للتزامن)
    // - التحديث (استخدام الكود) مسموح للطلاب إذا كان الكود متاحاً ولم يستخدم
    match /access_codes/{codeId} {
      allow read, list: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (
          resource.data.isUsed == false && 
          request.resource.data.isUsed == true && 
          request.resource.data.usedByStudentId == request.auth.uid
        )
      );
    }

    // بيانات الطلاب: الطالب يملك صلاحية كاملة على مجلده
    match /students/{studentId} {
      allow read, write: if isOwner(studentId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(studentId) || isAdmin();
      }
    }

    // دعم استعلامات المجموعات (Collection Group)
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/enrollments/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
  }
}