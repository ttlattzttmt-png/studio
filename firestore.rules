rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه مسؤول (Admin)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@al-bashmohandes.com" ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    // دالة التحقق من ملكية البيانات
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- القواعد ---

    // الإشعارات
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // أدوار ومستخدمي الإدارة
    match /admin_roles/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com");
    }
    match /admin_users/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
    }

    // الكورسات ومحتواها
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /{allSubcollections=**} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // أكواد الوصول (Access Codes): الحل النهائي للصلاحيات
    match /access_codes/{codeId} {
      // السماح بالبحث والقراءة لجميع المسجلين للتحقق من الكود
      allow read, list: if isSignedIn();
      // السماح للأدمن بالتحكم الكامل
      allow create, delete: if isAdmin();
      // السماح للطالب بتحديث الكود "فقط" إذا كان متاحاً (isUsed == false)
      // هذا هو المفتاح لحل مشكلة الصلاحيات نهائياً
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.isUsed == false
      );
    }

    // بيانات الطلاب واشتراكاتهم: الطالب يملك صلاحية كاملة على مجلده
    match /students/{studentId} {
      allow read, write: if isOwner(studentId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(studentId) || isAdmin();
      }
    }

    // دعم استعلامات المجموعات للمشرفين
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/enrollments/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
  }
}