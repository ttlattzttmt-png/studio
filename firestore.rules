rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه المسؤول المالك (عبر البريد الإلكتروني المعتمد)
    function isOwnerAdmin() {
      return isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com";
    }

    // --- القاعدة الذهبية: المسؤول له صلاحيات مطلقة وشاملة على كل شيء ---
    match /{allPaths=**} {
      allow read, write, delete: if isOwnerAdmin();
    }

    // --- قواعد عامة للجميع (طلاب وزوار) ---
    
    // الإشعارات - متاحة للجميع للقراءة والبحث (لأنها إعلانات عامة)
    match /notifications/{id} {
      allow read, list: if true;
    }

    // الكورسات - متاحة للقراءة والبحث للجميع لتصفح المكتبة
    match /courses/{courseId} {
      allow read, list: if true;
      
      // المحتوى الداخلي للكورسات - متاح فقط للمسجلين (سيتم فلترته برمجياً حسب الاشتراك)
      match /{allSubcollections=**} {
        allow read, list: if isSignedIn();
      }
    }

    // بيانات الطلاب - الطالب يرى ويحدث بياناته فقط بمساره الخاص (Path-Based Ownership)
    match /students/{studentId} {
      allow read, write: if isSignedIn() && request.auth.uid == studentId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // الأكواد - مسموح للطلاب بالتحقق منها وتحديث حالتها عند الاستخدام
    match /access_codes/{id} {
      allow read, update: if isSignedIn();
    }
    
    // دعم استعلام المجموعات للمسؤول فقط (Collection Groups)
    match /{path=**}/enrollments/{id} {
      allow read, list: if isOwnerAdmin();
    }
    
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isOwnerAdmin();
    }
  }
}