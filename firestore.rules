rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه المسؤول المالك
    function isOwnerAdmin() {
      return isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com";
    }

    // --- قاعدة المسؤول: له كل الصلاحيات على كل شيء ---
    match /{allPaths=**} {
      allow read, write, delete: if isOwnerAdmin();
    }

    // --- البيانات العامة: متاحة للجميع للقراءة والبحث (تمنع ايرور الدخول) ---
    match /notifications/{id} {
      allow read, list: if true;
    }

    match /courses/{courseId} {
      allow read, list: if true;
      
      // المحتوى الداخلي للكورسات
      match /{allSubcollections=**} {
        allow read, list: if isSignedIn();
      }
    }

    // --- بيانات الطلاب: كل طالب يتحكم في مساره الخاص فقط ---
    match /students/{studentId} {
      allow read, write: if isSignedIn() && request.auth.uid == studentId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // الأكواد
    match /access_codes/{id} {
      allow read, update: if isSignedIn();
    }
    
    // دعم استعلام المجموعات للمسؤول فقط
    match /{path=**}/enrollments/{id} {
      allow read, list: if isOwnerAdmin();
    }
    
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isOwnerAdmin();
    }
  }
}