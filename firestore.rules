rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@al-bashmohandes.com") ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // الإشعارات العامة: قراءة للجميع، كتابة للمسؤول
    match /notifications/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // أدوار المسؤولين
    match /admin_roles/{uid} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    // بيانات المسؤولين
    match /admin_users/{adminUserId} {
      allow read, list: if isAdmin();
      allow write: if isAdmin() && isOwner(adminUserId);
    }

    // بيانات الطلاب والاشتراكات
    match /students/{studentId} {
      allow get, update, create: if isOwner(studentId) || isAdmin();
      allow list: if isAdmin();
      allow delete: if isAdmin();

      match /enrollments/{enrollmentId} {
        allow read, list, write: if isOwner(studentId) || isAdmin();
      }
      match /quiz_attempts/{attemptId} {
        allow read, list, write: if isOwner(studentId) || isAdmin();
        
        match /answers/{answerId} {
          allow read, list, write: if isOwner(studentId) || isAdmin();
        }
      }
      match /video_progress/{progressId} {
        allow read, list, write: if isOwner(studentId) || isAdmin();
      }
    }

    // دعم استعلامات المجموعات (Collection Group) للمسؤول والطلاب
    match /{path=**}/quiz_attempts/{attemptId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/answers/{answerId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/enrollments/{enrollmentId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }

    // الكورسات والمحتوى: قراءة للجميع، كتابة للمسؤول
    match /courses/{courseId} {
      allow read, list: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read, list: if true;
        allow write: if isAdmin();
        
        match /questions/{questionId} {
          allow read, list: if isSignedIn(); 
          allow write: if isAdmin();
          match /options/{optionId} {
            allow read, list: if isSignedIn();
            allow write: if isAdmin();
          }
        }
      }
    }

    // أكواد الوصول: قراءة وتحديث للمسجلين، إنشاء وحذف للمسؤول
    match /access_codes/{accessCodeId} {
      allow read, list, update: if isSignedIn();
      allow create, delete: if isAdmin();
    }
  }
}