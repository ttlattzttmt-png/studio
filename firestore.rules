rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه المسؤول المالك (عبر البريد الإلكتروني) - الأولوية القصوى
    function isOwnerAdmin() {
      return isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com";
    }

    // دالة التحقق من صلاحيات المسؤول عبر قاعدة البيانات
    function hasAdminRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- القاعدة الذهبية: المسؤول له صلاحيات مطلقة وشاملة ---
    match /{allPaths=**} {
      allow read, write, delete: if isOwnerAdmin() || hasAdminRole();
    }

    // --- قواعد مخصصة لضمان عمل المنصة للطلاب ---

    // الكورسات متاحة للقراءة للجميع
    match /courses/{courseId} {
      allow read: if true;
      // السماح بالحذف الصريح للأدمن (تأكيد إضافي)
      allow delete: if isOwnerAdmin() || hasAdminRole();
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write, delete: if isOwnerAdmin() || hasAdminRole();
      }
    }

    // الإشعارات
    match /notifications/{id} {
      allow read: if true;
    }

    // بيانات الطلاب (الطالب يرى بياناته فقط)
    match /students/{studentId} {
      allow read, write: if isSignedIn() && request.auth.uid == studentId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // الأكواد
    match /access_codes/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}