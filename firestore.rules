rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه مسؤول (Admin)
    // نتحقق من البريد المخصص أو وجود سجل في admin_roles
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@al-bashmohandes.com" ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    // دالة التحقق من ملكية البيانات (للطالب)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- القواعد العامة ---

    // الإشعارات: الكل يقرأ، الأدمن يكتب
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // سجلات الأدمن
    match /admin_roles/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com");
    }
    match /admin_users/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
    }

    // الكورسات ومحتوياتها
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
        
        match /{allSubcollections=**} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // الأكواد: الأدمن يتحكم بالكل
    match /access_codes/{id} {
      allow read, write: if isAdmin();
      // السماح للطالب بتحديث كود واحد عند استخدامه (إذا قررت تفعيل نظام الأكواد مستقبلاً)
      allow update: if isSignedIn();
    }

    // بيانات الطلاب (Path-based ownership)
    match /students/{studentId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow write: if isOwner(studentId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read: if isOwner(studentId) || isAdmin();
        allow write: if isOwner(studentId) || isAdmin();
      }
    }

    // --- قواعد الـ Collection Group (ضرورية لصفحات الأدمن المتزامنة) ---
    
    // السماح للأدمن بقراءة كافة الاشتراكات من كل الطلاب
    match /{path=**}/enrollments/{id} {
      allow read, list: if isAdmin();
    }
    
    // السماح للأدمن بقراءة كافة محاولات الامتحانات من كل الطلاب
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isAdmin();
    }

    match /{path=**}/video_progress/{id} {
      allow read, list: if isAdmin();
    }
  }
}