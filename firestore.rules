rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه مسؤول (Admin) - التحقق المباشر والأكيد
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@al-bashmohandes.com" || 
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    // --- قاعدة ذهبية: المسؤول له صلاحيات مطلقة على كل شيء ---
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- قواعد مخصصة للطلاب (لضمان عمل المنصة بشكل طبيعي) ---

    // الكورسات متاحة للقراءة للجميع
    match /courses/{courseId} {
      allow read: if true;
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
      }
    }

    // الإشعارات
    match /notifications/{id} {
      allow read: if true;
    }

    // بيانات الطلاب (الطالب يرى بياناته فقط، والأدمن يرى الكل عبر القاعدة العامة أعلاه)
    match /students/{studentId} {
      allow read, write: if isSignedIn() && request.auth.uid == studentId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // السماح بالاستعلام عن الأكواد للطلاب للتحقق منها
    match /access_codes/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}