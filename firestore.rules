rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Al-Bashmohandes Platform Security Rules - Final Production Version
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // التحقق من أن المستخدم هو المسؤول
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@al-bashmohandes.com") ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // التحقق من اشتراك الطالب في الكورس
    function isEnrolled(courseId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/students/$(request.auth.uid)/enrollments/$(courseId)) ||
        isAdmin()
      );
    }

    // --- Collection Group Rules (Must be defined to allow collectionGroup queries) ---
    
    match /{path=**}/quiz_attempts/{attemptId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.studentId == request.auth.uid);
    }
    
    match /{path=**}/enrollments/{enrollmentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.studentId == request.auth.uid);
    }
    
    match /{path=**}/answers/{answerId} {
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.studentId == request.auth.uid));
      allow write: if isAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.studentId == request.auth.uid));
    }

    // --- Standard Collection Rules ---

    match /admin_roles/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == uid && request.auth.token.email.lower() == "admin@al-bashmohandes.com");
      allow update, delete: if isAdmin();
    }

    match /admin_users/{adminUserId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && isOwner(adminUserId);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow get: if isOwner(studentId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /content/{contentId} {
        allow get, list: if isAdmin() || isEnrolled(courseId);
        allow create, update, delete: if isAdmin();

        match /questions/{questionId} {
          allow get, list: if isAdmin() || isEnrolled(courseId);
          allow create, update, delete: if isAdmin();

          match /options/{optionId} {
            allow get, list: if isAdmin() || isEnrolled(courseId);
            allow create, update, delete: if isAdmin();
          }
        }
      }
    }

    match /access_codes/{accessCodeId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedByStudentId', 'usedAt']));
    }

    match /students/{studentId}/enrollments/{enrollmentId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /students/{studentId}/video_progress/{progressId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create, update: if isOwner(studentId);
      allow delete: if isAdmin();
    }

    match /students/{studentId}/quiz_attempts/{attemptId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();

      match /answers/{answerId} {
        allow get, list: if isOwner(studentId) || isAdmin();
        allow create: if isOwner(studentId);
        allow update: if isOwner(studentId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /notifications/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}