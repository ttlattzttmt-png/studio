rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه مسؤول (Admin)
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@al-bashmohandes.com") ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    // دالة التحقق من ملكية البيانات (Path-based ownership)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- القواعد الأساسية ---

    // الإشعارات: قراءة للجميع، كتابة للمسؤول
    match /notifications/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // أدوار ومستخدمي الإدارة
    match /admin_roles/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /admin_users/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow write: if isAdmin();
    }

    // الكورسات ومحتواها: قراءة للجميع، كتابة للمسؤول
    match /courses/{courseId} {
      allow read, list: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read, list: if true;
        allow write: if isAdmin();
        
        match /questions/{questionId} {
          allow read, list: if isSignedIn(); 
          allow write: if isAdmin();
          match /options/{optionId} {
            allow read, list: if isSignedIn();
            allow write: if isAdmin();
          }
        }
      }
    }

    // أكواد الوصول: قراءة وتحديث للمسجلين (لتفعيل الكود)، إنشاء وحذف للمسؤول
    match /access_codes/{codeId} {
      allow read, list, update: if isSignedIn();
      allow create, delete: if isAdmin();
    }

    // بيانات الطلاب: الطالب يملك صلاحية كاملة على مجلده وكل ما بداخله
    match /students/{studentId} {
      allow read, write: if isOwner(studentId) || isAdmin();
      
      // السماح بجميع العمليات على المجموعات الفرعية (الاشتراكات، المحاولات، إلخ)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(studentId) || isAdmin();
      }
    }

    // دعم استعلامات المجموعات (Collection Group) للمسؤول
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/enrollments/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/answers/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
  }
}