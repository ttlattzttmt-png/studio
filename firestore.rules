rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@al-bashmohandes.com" ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    // صلاحيات مطلقة للمسؤول على كل شيء
    match /{allPaths=**} {
      allow read, write, delete: if isOwnerAdmin();
    }

    // قواعد الإشعارات: قراءة للكل، كتابة للمسؤول
    match /notifications/{id} {
      allow read, list: if true;
    }

    // الكورسات والمحتوى
    match /courses/{courseId} {
      allow read, list: if true;
      
      match /content/{contentId} {
        allow read, list: if isSignedIn();
        
        match /questions/{qId} {
          allow read, list: if isSignedIn();
          match /options/{oId} {
             allow read, list: if isSignedIn();
          }
        }
      }
    }

    // الأكواد
    match /access_codes/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedByStudentId', 'usedAt']);
    }

    // بيانات الطلاب والتقدم والامتحانات
    match /students/{studentId} {
      allow read, write: if isSignedIn() && request.auth.uid == studentId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // دعم استعلام المجموعات للادمن (ضروري لصفحة الإحصائيات)
    match /{path=**}/enrollments/{id} {
      allow read, list: if isOwnerAdmin();
    }
    
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isOwnerAdmin();
    }

    match /{path=**}/video_progress/{id} {
      allow read, list: if isOwnerAdmin();
    }
  }
}