rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من كونه المسؤول المالك (عبر البريد الإلكتروني)
    function isOwnerAdmin() {
      return isSignedIn() && request.auth.token.email == "admin@al-bashmohandes.com";
    }

    // --- القاعدة الذهبية: المسؤول له صلاحيات مطلقة وشاملة ---
    match /{allPaths=**} {
      allow read, write, delete: if isOwnerAdmin();
    }

    // --- قواعد عامة للجميع ---
    
    // الإشعارات - متاحة للجميع للقراءة (لضمان عدم حدوث ايرور للطلاب)
    match /notifications/{id} {
      allow read, list: if true;
    }

    // الكورسات - متاحة للقراءة للجميع لتصفح المكتبة
    match /courses/{courseId} {
      allow read: if true;
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
      }
    }

    // بيانات الطلاب - الطالب يرى ويحدث بياناته فقط بمساره الخاص
    match /students/{studentId} {
      allow read, write: if isSignedIn() && request.auth.uid == studentId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // الأكواد
    match /access_codes/{id} {
      allow read, update: if isSignedIn();
    }
    
    // دعم استعلام المجموعات للمسؤول
    match /{path=**}/enrollments/{id} {
      allow read, list: if isOwnerAdmin();
    }
    
    match /{path=**}/quiz_attempts/{id} {
      allow read, list: if isOwnerAdmin();
    }
  }
}