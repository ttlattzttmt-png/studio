rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "admin@al-bashmohandes.com" ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // الإشعارات العامة: قراءة للجميع، كتابة للمسؤول فقط
    match /notifications/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /admin_roles/{uid} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /admin_users/{adminUserId} {
      allow read, list: if isAdmin();
      allow write: if isAdmin() && isOwner(adminUserId);
    }

    match /students/{studentId} {
      allow get, update: if isOwner(studentId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(studentId);
      allow delete: if isAdmin();

      match /enrollments/{enrollmentId} {
        allow read, list: if isOwner(studentId) || isAdmin();
        allow write: if isAdmin() || isOwner(studentId);
      }
      match /quiz_attempts/{attemptId} {
        allow read, list: if isOwner(studentId) || isAdmin();
        allow write: if isAdmin() || isOwner(studentId);
        
        match /answers/{answerId} {
          allow read, list: if isOwner(studentId) || isAdmin();
          allow write: if isAdmin() || isOwner(studentId);
        }
      }
      match /video_progress/{progressId} {
        allow read, list: if isOwner(studentId) || isAdmin();
        allow write: if isAdmin() || isOwner(studentId);
      }
    }

    // دعم استعلامات المجموعات (Collection Group) للمسؤول والمالك
    match /{path=**}/quiz_attempts/{attemptId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/answers/{answerId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
    match /{path=**}/enrollments/{enrollmentId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }

    match /courses/{courseId} {
      allow read, list: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read, list: if true;
        allow write: if isAdmin();
        
        match /questions/{questionId} {
          allow read, list: if isSignedIn(); 
          allow write: if isAdmin();
          match /options/{optionId} {
            allow read, list: if isSignedIn();
            allow write: if isAdmin();
          }
        }
      }
    }

    match /access_codes/{accessCodeId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedByStudentId', 'usedAt']));
    }
  }
}